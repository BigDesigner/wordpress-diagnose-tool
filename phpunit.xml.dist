<?xml version="1.0" encoding="UTF-8"?>
<phpunit bootstrap="tests/bootstrap.php"
         colors="true"
         cacheDirectory=".phpunit.cache"
         beStrictAboutOutputDuringTests="true">
    <testsuites>
        <testsuite name="WP Diagnose Unit">
            <directory>tests/Unit</directory>
        </testsuite>
    </testsuites>
</phpunit>
